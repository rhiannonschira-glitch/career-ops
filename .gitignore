# Personal data — NOW TRACKED (this is your private fork)
# cv.md — TRACKED
# config/profile.yml — TRACKED
# modes/_profile.md — TRACKED
# portals.yml — TRACKED
# data/applications.md — TRACKED
# data/pipeline.md — TRACKED
# data/scan-history.tsv — TRACKED

# Reports — tracked so Hermes can sync them
# reports/*.md — TRACKED
!reports/.gitkeep

# Output PDFs — generated, don't track
output/*
!output/.gitkeep

# Batch working files
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep

# JDs — optional, can track if you want
jds/*
!jds/.gitkeep

# Writing samples (user's personal files)
writing-samples/*
!writing-samples/README.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json